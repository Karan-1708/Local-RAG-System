# --- Local RAG System Configuration Example ---
# Copy this file to '.env' and fill in your details.
# DO NOT COMMIT YOUR REAL '.env' FILE TO GIT.

# --- Tesseract OCR ---
# Full path to the Tesseract executable (required for OCR on PDFs/Images).
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/macOS: usually /usr/bin/tesseract or /usr/local/bin/tesseract
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# --- Models ---
# Default model to use if no selection is made.
LLM_MODEL=llama3:8b
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Required only if you want to use HuggingFace features or certain models.
HF_TOKEN=your_huggingface_token_here

# --- RAG Parameters ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5
SIMILARITY_THRESHOLD=0.6

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=local_rag.log

# --- Privacy ---
# Set to 1 to force offline mode for HuggingFace Transformers.
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# --- API Keys (Leave blank to use sidebar input) ---
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=
