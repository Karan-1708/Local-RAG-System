# Template for .env file. Copy this to .env and adjust the values.

# --- Tesseract OCR ---
# Windows example: C:\....\TesseractOCR\tesseract.exe
TESSERACT_CMD=C:\....\TesseractOCR\tesseract.exe

# --- Models ---
LLM_MODEL=llama3:8b
EMBEDDING_MODEL=all-MiniLM-L6-v2
HF_TOKEN=your_huggingface_token_here

# --- RAG Parameters ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5
SIMILARITY_THRESHOLD=0.6

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=local_rag.log
